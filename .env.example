# ─── Supabase (public — bundled into the app) ───
# From Supabase dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Server-side only (NEVER prefix with EXPO_PUBLIC_) ───
# Used by scripts/ (question generation, admin tasks). Keep secret.
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# From Supabase dashboard → Settings → API → service_role key
# Bypasses RLS — ONLY use in trusted server scripts, never in the app
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Full Postgres connection string for running DDL migrations (CREATE TABLE etc.)
# Dashboard → Project Settings → Database → Connection string → URI (toggle "Show password")
# Format: postgres://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_DB_URL=postgres://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres
